{
  "name": "@codematic.io/cdp-editor",
  "version": "4.0.2",
  "description": "A powerful rich-text email editor with HTML code view, template variables, image management, and CSS inlining",
  "type": "module",
  "main": "./dist/email-editor.umd.cjs",
  "module": "./dist/email-editor.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/email-editor.es.js",
      "require": "./dist/email-editor.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:deploy": "npm run build && firebase deploy",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "homepage": "https://cdp-editor-064.web.app",
  "keywords": [
    "React",
    "Rich Text Editor",
    "TailwindCSS",
    "Ant Design",
    "WYSIWYG",
    "Component",
    "Customizable",
    "openCDP",
    "Editor",
    "JavaScript",
    "TypeScript",
    "UI",
    "Modern",
    "Integration",
    "Plugin",
    "Formatting",
    "Toolbar",
    "Content",
    "Library",
    "Open Source"
  ],
  "author": "codematic.io",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@monaco-editor/react": ">=4.0.0",
    "antd": ">=5.0.0",
    "currency-codes": ">=2.0.0",
    "juice": ">=10.0.0",
    "liquidjs": ">=10.0.0",
    "react-simple-wysiwyg": ">=3.0.0",
    "sonner": ">=1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.2.1",
    "vite-plugin-dts": "^4.5.3"
  }
}
